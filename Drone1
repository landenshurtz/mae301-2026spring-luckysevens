def upload_mission(waypoints):
    # Clear any previous mission
    connection.mav.mission_clear_all_send(#hey dorneclear the mission
        connection.target_system,#tells the right drone
        connection.target_component,#tells the right drone system(autopilot)
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION#tells what kind of data needs to be cleared (mission data not other data like an invisible wall)
    )

    time.sleep(1) #?

    # Tell vehicle how many waypoints are coming
    connection.mav.mission_count_send(
        connection.target_system,
        connection.target_component,
        len(waypoints),#length of misson vector (how many mission to fly)
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION#specifies this count refers to the main mision data
    )

    sent = 0 #counter, every time a misson is complete 1 is added to the counter
    while True: #keep checking until upload is finished
        msg = connection.recv_match( # listen for these particular message types so it ignores unrelated messages
            type=["MISSION_REQUEST_INT", "MISSION_REQUEST", "MISSION_ACK"], #mission number, mission sequence, mision sucesfully uploaded (acknoleged)
            blocking=True, #waits untill one of these messages is received ?which one
            timeout=10 #will wait ten seconds for a mission relatted message ?what does the interaction look like, donr to ground control
        )

        if msg is None: #if there is no response form the drone
            raise TimeoutError("Mission upload timed out")

        msg_type = msg.get_type() # finds out what type of misson message the drone sent

        if msg_type in ["MISSION_REQUEST_INT", "MISSION_REQUEST"]: #if dorne is requesting a waypoint (sequence and mission)
            seq = msg.seq #sets teh sequence we are currently on
            print(f"Vehicle requested mission item {seq}") 
            connection.mav.send(waypoints[seq]) #sends specific mission using the sequence number the drone requested
            sent += 1 #now knows I sent whatever number of sent mission plus one so it will ask for the next sequential mission

        elif msg_type == "MISSION_ACK": # if the message type is an ascknolegement of a mission upload
            print(f"Mission upload complete: type={msg.type}")
            break # no need to wait the upload is complete

