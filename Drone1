def set_mode(mode_name: str): # Mathcnes the mode id to the string becuase ArduPilot expects an id not a stirng but humans dont talk in ids
    mode_id = connection.mode_mapping().get(mode_name) #looks at intern mapping of mode ids and their respective names
    if mode_id is None:
        raise ValueError(f"Unknown mode: {mode_name}") # could not actually find the mode id from the given name string

    connection.mav.set_mode_send( # sets the new mode through the MAVlink connection by telling it the new mod eid to chang eto
        connection.target_system,
        mavutil.mavlink.MAV_MODE_FLAG_CUSTOM_MODE_ENABLED,
        mode_id
    )

def arm():
    connection.mav.command_long_send(
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_CMD_COMPONENT_ARM_DISARM,
        0,
        1,  # arm
        0, 0, 0, 0, 0, 0
    )

def disarm():
    connection.mav.command_long_send(
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_CMD_COMPONENT_ARM_DISARM,
        0,
        0,  # disarm
        0, 0, 0, 0, 0, 0
    )

def takeoff(altitude_m: float): #DONT USE THIS LOWKEY, KINDA JUST HRE IN CASE
    connection.mav.command_long_send(
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_CMD_NAV_TAKEOFF,
        0,
        0, 0, 0, 0,   # unused params for Copter
        0, 0, altitude_m
    )

def rtl():
    connection.mav.command_long_send(
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_CMD_NAV_RETURN_TO_LAUNCH,
        0,
        0, 0, 0, 0, 0, 0, 0
    )

def send_body_velocity(vx, vy, vz): # saving this for reactions from AI not so much mission contoll 
    # Body-frame velocity command.
    # vx forward, vy right, vz down (m/s)
    type_mask = (
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_X_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_Y_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_Z_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_AX_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_AY_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_AZ_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_YAW_IGNORE |
        mavutil.mavlink.POSITION_TARGET_TYPEMASK_YAW_RATE_IGNORE
    )

    connection.mav.set_position_target_local_ned_send(
        0,
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_FRAME_BODY_NED,
        type_mask,
        0, 0, 0,      # position ignored
        vx, vy, vz,   # velocity used
        0, 0, 0,      # accel ignored
        0, 0          # yaw/yaw_rate ignored
    )

def make_takeoff_item(seq, lat, lon, alt):
    return mavutil.mavlink.MAVLink_mission_item_int_message( #misson message (integers)
        connection.target_system,
        connection.target_component,
        seq, #which posison in the sequence
        mavutil.mavlink.MAV_FRAME_GLOBAL_RELATIVE_ALT_INT, # define cordinate system
        mavutil.mavlink.MAV_CMD_NAV_TAKEOFF,# 
        0,   # current
        1,   # autocontinue
        0, 0, 0, 0,                  # param1-4
        int(lat * 1e7),              # x = latitude
        int(lon * 1e7),              # y = longitude
        alt,                         # z = altitude
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION
    )

def make_rtl_item(seq):
    return mavutil.mavlink.MAVLink_mission_item_int_message(
        connection.target_system,
        connection.target_component,
        seq,
        mavutil.mavlink.MAV_FRAME_MISSION,
        mavutil.mavlink.MAV_CMD_NAV_RETURN_TO_LAUNCH,
        0,   # current
        1,   # autocontinue
        0, 0, 0, 0,                  # param1-4
        0,                           # x unused
        0,                           # y unused
        0,                           # z unused
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION
    )

def make_waypoint_item(seq, lat, lon, alt): # creates a mission packet to eventually send to the drone

    return mavutil.mavlink.MAVLink_mission_item_int_message( #contrcuts the MAVlink mission object (with integers) 
        connection.target_system, #finds correct vehicle
        connection.target_component, #finds correct sytem in that vehicle (would be a id in real life, is this brute forceable?)
        seq, #specifies which site in the mission order
        mavutil.mavlink.MAV_FRAME_GLOBAL_RELATIVE_ALT_INT, #specifies the cordinate sysetm( lat, lon, alt in integer form)
        mavutil.mavlink.MAV_CMD_NAV_WAYPOINT, # mission is a "normal" waaypoint navigation command (pther commands could be loiter RTL etc)
        0,   # current, left at zero becuase this is not the current mission, but will be changed to one
        1,   # autocontinue once this missin is complete (1 = yes)
        0, 0, 0, 0,                  # param1-4 not used
        int(lat * 1e7), #specifed lat
        int(lon * 1e7), #specifed lon
        alt, #altitude lol
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION #says this is waypoint item not a differnt navigations item such as an invisible wall
    )

