def make_takeoff_item(seq, lat, lon, alt):
    return mavutil.mavlink.MAVLink_mission_item_int_message( #misson message (integers)
        connection.target_system,
        connection.target_component,
        seq, #which posison in the sequence
        mavutil.mavlink.MAV_FRAME_GLOBAL_RELATIVE_ALT_INT, # define cordinate system
        mavutil.mavlink.MAV_CMD_NAV_TAKEOFF,# 
        0,   # current
        1,   # autocontinue
        0, 0, 0, 0,                  # param1-4
        int(lat * 1e7),              # x = latitude
        int(lon * 1e7),              # y = longitude
        alt,                         # z = altitude
        mavutil.mavlink.MAV_MISSION_TYPE_MISSION
    )

def make_rtl_item(seq):
