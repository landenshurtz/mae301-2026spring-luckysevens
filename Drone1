def set_mode(mode_name: str): # Mathcnes the mode id to the string becuase ArduPilot expects an id not a stirng but humans dont talk in ids
    mode_id = connection.mode_mapping().get(mode_name) #looks at intern mapping of mode ids and their respective names
    if mode_id is None:
        raise ValueError(f"Unknown mode: {mode_name}") # could not actually find the mode id from the given name string

    connection.mav.set_mode_send( # sets the new mode through the MAVlink connection by telling it the new mod eid to chang eto
        connection.target_system,
        mavutil.mavlink.MAV_MODE_FLAG_CUSTOM_MODE_ENABLED,
        mode_id
    )

def arm():
    connection.mav.command_long_send(
        connection.target_system,
        connection.target_component,
        mavutil.mavlink.MAV_CMD_COMPONENT_ARM_DISARM,
        0,
        1,  # arm
        0, 0, 0, 0, 0, 0
    )

